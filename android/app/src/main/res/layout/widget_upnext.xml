<?xml version="1.0" encoding="utf-8"?>
<!-- ShowBoat Up Next Widget — 4×2 watchlist preview -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_upnext_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Up Next"
            android:textColor="#38bdf8"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_upnext_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#64748b"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/widget_upnext_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_upnext_type_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📺 TV"
            android:textColor="#94a3b8"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_upnext_name_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/widget_upnext_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_upnext_type_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📺 TV"
            android:textColor="#94a3b8"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_upnext_name_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/widget_upnext_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_upnext_type_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📺 TV"
            android:textColor="#94a3b8"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_upnext_name_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
