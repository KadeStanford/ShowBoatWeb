<?xml version="1.0" encoding="utf-8"?>
<!-- ShowBoat Recent Ratings Widget — 4×2 latest ratings -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_recent_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⭐ Recent Ratings"
            android:textColor="#facc15"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_recent_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#64748b"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/widget_recent_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_recent_name_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_recent_score_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#facc15"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/widget_recent_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_recent_name_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_recent_score_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#facc15"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/widget_recent_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_recent_name_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_recent_score_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#facc15"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
