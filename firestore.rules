rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users can read/write their own data and all subcollections
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    // Any authenticated user can read other user profiles (for friend search)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    // Mutual friends: either party can add/remove the friendship record
    // (addFriend writes to both users' /friends/ subcollections)
    match /users/{userId}/friends/{friendId} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == friendId);
    }
    // Shames: the shamer can write to the shamed user's subcollection
    match /users/{userId}/shames/{shameId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }
    // Recommendations: any authenticated user can send a recommendation
    // to another user (writes to the receiver's subcollection)
    match /users/{userId}/recommendations/{recId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
    // Notifications: cross-user notifications (e.g. shame-watched alerts)
    match /users/{userId}/notifications/{notifId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
    // Reactions: any authenticated user can react to another user's episode ratings
    match /users/{userId}/episodeRatings/{ratingId}/reactions/{reactorId} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.uid == reactorId;
    }
    // Shared resources accessible to all authenticated users
    match /shames/{shameId} {
      allow read, write: if request.auth != null;
    }
    match /matcherSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
    match /sharedLists/{listId} {
      allow read, write: if request.auth != null;
    }
    match /sharedLists/{listId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ==================== ADMIN COLLECTIONS ====================
    // Invite codes: admin full access; anyone can read (validation before signup);
    // authenticated users can mark a code as used or create codes they own
    match /inviteCodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if request.auth != null
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.active == false;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.active == true;
    }
    // Ticket requests: authenticated users can create, admin can read/update
    match /ticketRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }
    // Waitlist: anyone can read (duplicate check) and add; admin has full access
    match /waitlist/{entryId} {
      allow read, create: if true;
      allow read, write: if isAdmin();
    }
    // User reports: authenticated users can create, admin can read/update
    match /userReports/{reportId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }
    // Bug reports: authenticated users can create, admin can read/update
    match /bugReports/{bugId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }
    // Announcements: admin can write/delete, all authenticated users can read
    match /announcements/{annId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
