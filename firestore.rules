rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data and subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Any authenticated user can read other user profiles (for friend search)
    match /users/{userId} {
      allow read: if request.auth != null;
    }
    // Shared resources accessible to all authenticated users
    match /shames/{shameId} {
      allow read, write: if request.auth != null;
    }
    match /matchSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
    match /sharedLists/{listId} {
      allow read, write: if request.auth != null;
    }
    match /sharedLists/{listId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
